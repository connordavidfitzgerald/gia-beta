--- 
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { Font, type CssVariable } from "astro:assets";
const FONTS: CssVariable[] = ["--font-sans", "--font-serif"];
---

<Layout title="Community Breakfasts — Gia">
    <a href="/community" slot="nav-links" class="nav-link active">Community Breakfasts</a>

    <!-- Main page content -->
    <div class="page-content">
        <!-- ─── PAGE HEADER ─── -->
        <div class="page-header">
            <div class="page-header-left">
                <div class="section-label">Community · Montréal</div>
                <h1>Community<br><em>Breakfasts.</em></h1>
            </div>
            <div class="page-header-right">
                <p>
                    Every few weeks, we bring together <strong>nonprofits, artists, and grant writers</strong> in Montréal for an informal morning conversation about funding, projects, and the things nobody tells you in the application forms.
                </p>
                <p>
                    Free to attend. Held at Brique par Brique in Parc-Extension. Come as you are.
                </p>
                <div class="hosting-badge">
                    <span class="badge-icon">🏡</span>
                    <div class="hosting-badge-text">
                        <strong>Hosted at Brique par Brique</strong>
                        <span>Parc-Extension, Montréal</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="divider"></div>

        <!-- ─── EVENTS ─── -->
        <section class="events-section">
            <!-- Upcoming callout -->
            <div class="upcoming-callout">
                <div>
                    <div class="upcoming-callout-tag">↑ Next breakfast</div>
                    <h2>Community Breakfast<br><em>#02 — May 2026</em></h2>
                    <p>
                        The second morning gathering — picking up the conversation from April. Bring a grant question, a project update, or just your coffee order.
                    </p>
                    <div class="upcoming-callout-meta">
                        <div class="upcoming-meta-item">📅 <strong>Date TBD</strong> · May 2026</div>
                        <div class="upcoming-meta-item">📍 <strong>Brique par Brique</strong> · Parc-Extension</div>
                        <div class="upcoming-meta-item">🕗 <strong>8:30 – 10:00 am</strong></div>
                    </div>
                </div>
                <div class="upcoming-callout-right">
                    <a href="#" class="btn-upcoming">Reserve your spot →</a>
                </div>
            </div>

            <div class="events-year-label">2026</div>

            <!-- Event 1 — Past (Beta launch, April 17) -->
            <a href="/events/breakfast-01" class="event-card">
                <div class="event-date">
                    <div class="event-date-day">17</div>
                    <div class="event-date-month">April</div>
                </div>
                <div class="event-info">
                    <div class="event-meta">
                        <span class="event-status past">
                            <span class="event-status-dot"></span>
                            Recap available
                        </span>
                        <span class="event-number">Breakfast #01</span>
                    </div>
                    <h2>The beta launch breakfast</h2>
                    <p>
                        Gia's first morning gathering — introducing the platform, listening to grant challenges from the community, and kicking off the beta with 30 friends from Montréal's OBNL and arts ecosystem.
                    </p>
                    <div class="event-tags">
                        <span class="event-tag">Beta launch</span>
                        <span class="event-tag">OBNLs</span>
                        <span class="event-tag">Artists</span>
                        <span class="event-tag">Grant writing</span>
                    </div>
                </div>
                <div class="event-card-right">
                    <div class="event-photo-count">📷 24 photos</div>
                    <div class="event-card-arrow">→</div>
                </div>
            </a>

            <!-- Event 2 — Upcoming -->
            <a href="/events/breakfast-02" class="event-card upcoming-event">
                <div class="event-date">
                    <div class="event-date-day">TBD</div>
                    <div class="event-date-month">May 2026</div>
                </div>
                <div class="event-info">
                    <div class="event-meta">
                        <span class="event-status upcoming">
                            <span class="event-status-dot"></span>
                            Coming up
                        </span>
                        <span class="event-number">Breakfast #02</span>
                    </div>
                    <h2>The community gathering</h2>
                    <p>
                        Building on our beta launch, this breakfast focuses on grant strategies, community building, and shaping Gia's future. Registration opening soon.
                    </p>
                    <div class="event-tags">
                        <span class="event-tag">Community building</span>
                        <span class="event-tag">Grant strategies</span>
                        <span class="event-tag">Artist support</span>
                    </div>
                </div>
                <div class="event-card-right">
                    <div class="event-photo-count"></div>
                    <div class="event-card-arrow">→</div>
                </div>
            </a>
        </section>
    </div>

    <!-- Event-specific scripts -->
    <script slot="scripts">
        // Add any event-specific JavaScript here
        console.log('Community page loaded');
    </script>
</Layout>

<style>
    .page-content {
        padding-top: 80px;
    }
</style>