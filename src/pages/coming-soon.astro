---
import "../styles/global.css";
import { Font, type CssVariable } from "astro:assets";
const FONTS: CssVariable[] = ["--font-sans", "--font-serif"];
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Gia — Coming Soon</title>
        {FONTS.map((font) => <Font cssVariable={font} preload />)}
    </head>
    <body>
        <nav>
            <div class="nav-logo">Gia</div>
            <div class="flex flex-row gap-0.5 justify-end">
                <a class="nav-cta-reg">Community Breakfasts</a>
                <a href="/coming-soon" class="nav-cta">Try Gia for free →</a>
            </div>
        </nav>
        <div class="coming-soon-page">
            <div class="coming-soon-content">
                <h1>Gia is still<br /><em>growing.</em></h1>

                <p class="coming-soon-subtitle">
                    Sign up for the waitlist to be the first to try it when we
                    launch.
                </p>

                <form id="email-form" class="email-signup">
                    <div class="email-input-wrap">
                        <input
                            type="email"
                            name="email"
                            class="email-input"
                            placeholder="Enter your email."
                            required
                        />
                        <button class="email-submit" type="submit">
                            <svg
                                class="email-submit-arrow"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                            >
                                <path
                                    d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"
                                ></path>
                            </svg>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Web3Forms Email Signup -->
        <script>
            const form = document.getElementById("email-form");
            const submitBtn = form.querySelector('button[type="submit"]');

            form.addEventListener("submit", async (e) => {
                e.preventDefault();

                const formData = new FormData(form);
                formData.append(
                    "access_key",
                    "cb47c73b-587b-47cf-894c-3aeea5b3d35b",
                );

                const originalText = submitBtn.innerHTML;

                submitBtn.innerHTML =
                    '<svg class="email-submit-arrow" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15 6L7 12L15 18L12 22L4 12Z"/></svg>';
                submitBtn.disabled = true;

                try {
                    const response = await fetch(
                        "https://api.web3forms.com/submit",
                        {
                            method: "POST",
                            body: formData,
                        },
                    );

                    const data = await response.json();

                    if (response.ok) {
                        alert(
                            "Success! Your email has been submitted. We'll notify you when Gia is ready.",
                        );
                        form.reset();
                    } else {
                        alert("Error: " + data.message);
                    }
                } catch (error) {
                    alert("Something went wrong. Please try again.");
                } finally {
                    submitBtn.innerHTML = originalText;
                    submitBtn.disabled = false;
                }
            });
        </script>
    </body>
</html>
