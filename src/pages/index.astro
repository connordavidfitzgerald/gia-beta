---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { Font, type CssVariable, Picture } from "astro:assets";
const FONTS: CssVariable[] = ["--font-sans", "--font-serif"];
import plant from "../assets/images/plant.png";
import ScrollSequence from "../components/ScrollSequence.astro";
import drawing from "../assets/images/gia_drawing_burg.png";
import quote from "../assets/images/quote-stickie.png";
---

<Layout>
    <section
        id="hero"
        class="relative h-screen min-h-[1080px] flex flex-col items-center justify-center gap-10"
    >
        <h1 class="font-serif text-7xl tracking-[-0.5%] text-center">
            Grants made<br /><span class=""></span>simple.
        </h1>
        <Picture src={drawing} alt="Gia drawing" class="w-[150px]" />
        <p
            class="font-sans text-[1rem] tracking-normal w-[400px] text-center leading-normal"
        >
            Gia restores the conversation between mission, practice and funders.
            Discovery is always free. We take 10%, only once funding is secured.
        </p>
        <a class="text-sm uppercase tracking-wide underline"
            >Join the waitlist</a
        >
        <div
            class="flex flex-col items-center justify-center absolute bottom-10"
        >
            <span>Learn more</span>
            <span>↓</span>
        </div>
    </section>
    <ScrollSequence />
    <section
        id="squares"
        class="h-fit px-6 flex flex-col justify-center items-center pb-80"
    >
        <div
            class="mx-auto max-w-[960px] flex justify-center items-center flex-col gap-8"
        >
            <h2
                class="font-serif text-2xl tracking-normal leading-tight text-center mb-8"
            >
                Gia, a new way to inhabit<br />the world of grants.
            </h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
                <div
                    class="bg-burgundy text-ivory aspect-square rounded-2xl flex flex-col justify-between items-start p-8"
                >
                    <h3
                        class="font-serif text-xl lg:text-xl tracking-normal leading-tight"
                    >
                        Gia is built on conversation.
                    </h3>
                    <p
                        class="font-sans text-lg sm:text-sm tracking-loose leading-normal text-ivory/70"
                    >
                        Gia is your private garden: fed by your official and
                        legal documents, the ones needed to move energy forward
                        and bring our visions into form. And the more Gia knows,
                        the sharper the matches.
                    </p>
                </div>
                <div
                    class="bg-burgundy text-ivory aspect-square rounded-2xl flex flex-col justify-between items-start p-8"
                >
                    <h3
                        class="font-serif text-xl lg:text-xl tracking-normal leading-tight"
                    >
                        Cultivate, with intention.
                    </h3>
                    <p
                        class="font-sans text-lg sm:text-sm tracking-loose leading-normal text-ivory/70"
                    >
                        Move forward with clarity through the noise. Gia
                        surfaces up to 5 grants that are most likely to succeed,
                        and explains why, in plain language, based on your
                        project and your organizational profile.
                    </p>
                </div>
                <div
                    class="bg-burgundy text-ivory aspect-square rounded-2xl flex flex-col justify-between items-start p-8"
                >
                    <h3
                        class="font-serif text-xl lg:text-xl tracking-normal leading-tight"
                    >
                        One project, one ecosystem.
                    </h3>
                    <p
                        class="font-sans text-lg sm:text-sm tracking-loose leading-normal text-ivory/70"
                    >
                        Grants follow projects. Each funding need has its own
                        project, with targeted grants and strategy.
                    </p>
                </div>
                <div
                    class="bg-burgundy text-ivory aspect-square rounded-2xl flex flex-col justify-between items-start p-8"
                >
                    <h3
                        class="font-serif text-xl lg:text-xl tracking-normal leading-tight"
                    >
                        Born from the same roots.
                    </h3>
                    <p
                        class="font-sans text-lg sm:text-sm tracking-loose leading-normal text-ivory/70"
                    >
                        Gia is a solidarity cooperative, run by the same kind of
                        organizations it supports. Here, mission leads.
                    </p>
                </div>
                <div
                    class="bg-burgundy text-ivory aspect-square rounded-2xl flex flex-col justify-between items-start p-8"
                >
                    <h3
                        class="font-serif text-xl lg:text-xl tracking-normal leading-tight"
                    >
                        Emotional intelligence as support.
                    </h3>
                    <p
                        class="font-sans text-lg sm:text-sm tracking-loose leading-normal text-ivory/70"
                    >
                        Gia holds deep knowledge of Québec and Canadian funders.
                        By combining cultural fluency and linguistic agility,
                        Gia becomes the third space that takes the system apart,
                        and puts it back together.
                    </p>
                </div>
                <div
                    class="bg-burgundy text-ivory aspect-square rounded-2xl flex flex-col justify-between items-start p-8"
                >
                    <h3
                        class="font-serif text-xl lg:text-xl tracking-normal leading-tight"
                    >
                        Cultivate, with intention.
                    </h3>
                    <p
                        class="font-sans text-lg sm:text-sm tracking-loose leading-normal text-ivory/70"
                    >
                        Gia is your private garden: fed by your official and
                        legal documents, the ones needed to move energy forward
                        and bring our visions into form. And the more Gia knows,
                        the sharper the matches.
                    </p>
                </div>
            </div>
        </div>
    </section>
    <section
        class="h-fit py-40 flex flex-col justify-center items-center gap-4 mt-30 bg-parchment rounded-2xl m-6"
    >
        <Picture
            src={quote}
            alt="quote"
            class="h-[350px] w-auto opacity-70 brightness-110"
        />
        <p
            class="font-sans text-base tracking-loose leading-normal text-burgundy/90"
        >
            beta user, untold truth, 160/175
        </p>
    </section>
    <section
        id="pricing"
        class="h-screen min-h-[1080px] flex flex-col justify-center items-center -mt-10"
    >
        <h2
            class="font-serif text-3xl tracking-normal leading-tight text-center"
        >
            How Gia grows with you.
        </h2>
        <p
            class="font-sans text-[16px] tracking-normal leading-normal text-burgundy pt-3 pb-12 text-center w-[400px]"
        >
            Exploration is always free.<br />We're with you all the way to the
            harvest.
        </p>
        <div class="flex flex-row w-[700px] h-[450px] gap-2 mt-10">
            <div
                class="bg-burgundy rounded-2xl flex flex-col justify-between h-full w-[50%] p-10 text-ivory"
            >
                <h3
                    class="font-sans text-[18px] tracking-normal leading-tight text-center pt-2"
                >
                    Exploration & matching
                    <br />
                    <span class="opacity-70">Free</span>
                </h3>
                <p
                    class="font-sans text-[16px] tracking-loose leading-normal opacity-50 pb-6 text-center"
                >
                    Everything starts with a conversation. We get to know you,
                    your projects, your work on the ground, your pace.<br />100%
                    free.
                </p>
                <a class="text-sm uppercase tracking-wide underline text-center"
                    >Join the waitlist</a
                >
            </div>
            <div
                class="bg-burgundy rounded-2xl flex flex-col justify-between h-full w-[50%] p-10 text-ivory"
            >
                <h3
                    class="font-sans text-[18px] tracking-normal leading-tight text-center pt-2"
                >
                    Writing with Gia
                    <br />
                    <span class="opacity-70">10% on success only </span>
                </h3>
                <p
                    class="font-sans text-[16px] tracking-loose leading-normal opacity-70 pb-6 text-center"
                >
                    A Gia grants writer writes with you and we're paid 10% of
                    the awarded amount, only if the grant comes through.
                </p>
                <a class="text-sm uppercase tracking-wide underline text-center"
                    >Contact Us</a
                >
            </div>
        </div>
        <p
            class="font-sans text-sm tracking-normal leading-normal text-burgundy/70 text-center w-[600px] rounded-2xl px-10 pt-4 mt-2"
        >
            Grant writers typically charge 8–12% of awarded amounts. Gia's 10%
            is intentionally at the lower end and zero risk to you.
        </p>
    </section>
</Layout>

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    // Walk only text nodes so <br>, <span>, and other tags are preserved as-is.
    function wrapWords(el: Element) {
        const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT);
        const textNodes: Text[] = [];
        let node: Node | null;
        while ((node = walker.nextNode())) textNodes.push(node as Text);

        for (const textNode of textNodes) {
            const words = (textNode.textContent ?? "")
                .trim()
                .split(/\s+/)
                .filter(Boolean);
            if (!words.length) continue;

            const frag = document.createDocumentFragment();
            words.forEach((word, i) => {
                if (i > 0) frag.appendChild(document.createTextNode(" "));
                const mask = document.createElement("span");
                mask.className = "rm";
                const inner = document.createElement("span");
                inner.className = "rw";
                inner.textContent = word;
                mask.appendChild(inner);
                frag.appendChild(mask);
            });
            textNode.parentNode?.replaceChild(frag, textNode);
        }
    }

    function reveal(selector: string, scroll: boolean, delay = 0) {
        const el = document.querySelector(selector);
        if (!el) return;
        wrapWords(el);
        const words = el.querySelectorAll<HTMLElement>(".rw");

        gsap.from(words, {
            y: "115%",
            duration: 1,
            ease: "power3.out",
            stagger: 0.03,
            delay: scroll ? 0 : delay,
            ...(scroll && {
                scrollTrigger: {
                    trigger: el,
                    start: "top 85%",
                },
            }),
        });
    }

    // Hero fires on load; squares and pricing fire on scroll
    reveal("#hero h1", false, 0.25);
    reveal("#squares h2", true);
    reveal("#pricing h2", true);
</script>
