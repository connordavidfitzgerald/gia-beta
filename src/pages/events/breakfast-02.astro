---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import { Font, type CssVariable } from "astro:assets";
const FONTS: CssVariable[] = ["--font-sans", "--font-serif"];
---

<Layout title="Breakfast #02 — Community gathering · Gia">
    <a href="/community" slot="nav-links" class="nav-link active"
        >Community Breakfasts</a
    >

    <div class="page-content">
        <!-- ─── EVENT HERO ─── -->
        <div class="event-hero">
            <div class="event-breadcrumb">
                <a href="/community">Community Breakfasts</a>
                <span>→</span>
                <span>Breakfast #02</span>
            </div>

            <div class="event-hero-grid">
                <div>
                    <div class="event-tag-row">
                        <span class="event-badge">📅 Upcoming</span>
                        <span class="event-number-badge"
                            >Breakfast #02 · May 2026</span
                        >
                    </div>
                    <h1>The <em>community</em><br />gathering.</h1>
                    <p class="event-hero-desc">
                        Building on the momentum from our beta launch, this
                        breakfast brings together artists, nonprofits, and grant
                        writers to share progress, discuss challenges, and
                        explore how Gia can better serve Montréal's creative
                        community.
                    </p>
                </div>

                <div class="event-meta-card">
                    <div class="meta-row">
                        <span class="meta-label">Date</span>
                        <span class="meta-value">Coming soon — May 2026</span>
                    </div>
                    <hr class="meta-divider" />
                    <div class="meta-row">
                        <span class="meta-label">Time</span>
                        <span class="meta-value">8:30 – 10:00 am</span>
                    </div>
                    <hr class="meta-divider" />
                    <div class="meta-row">
                        <span class="meta-label">Location</span>
                        <span class="meta-value"
                            >Brique par Brique<br />Parc-Extension, Montréal</span
                        >
                    </div>
                    <hr class="meta-divider" />
                    <div class="meta-row">
                        <span class="meta-label">Status</span>
                        <span class="meta-value">Registration opening soon</span
                        >
                    </div>
                    <hr class="meta-divider" />
                    <div class="meta-row">
                        <span class="meta-label">Topics</span>
                        <div class="meta-tags">
                            <span class="meta-tag">Community building</span>
                            <span class="meta-tag">Grant strategies</span>
                            <span class="meta-tag">Artist support</span>
                            <span class="meta-tag">Platform feedback</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ─── BODY: EVENT DETAILS + SIDEBAR ─── -->
        <div class="event-body">
            <!-- Event Details -->
            <div class="event-recap">
                <div class="recap-summary">
                    <div class="recap-section-label">About this event</div>
                    <h2>What to <em>expect</em><br />this time.</h2>
                    <p>
                        Following the success of our beta launch breakfast,
                        we're continuing the conversation. This gathering will
                        focus on practical grant strategies, sharing experiences
                        from early Gia users, and discussing how we can
                        collectively navigate Montréal's funding landscape more
                        effectively.
                    </p>
                    <p>
                        Whether you attended the first breakfast or this is your
                        introduction to Gia, you'll leave with actionable
                        insights, new connections, and a clearer path forward
                        for your projects. We'll have updates on Gia's
                        development, stories from organizations that have used
                        the platform, and plenty of time for open discussion.
                    </p>
                    <p>
                        Coffee and light breakfast provided. All are welcome —
                        artists, nonprofit leaders, grant writers, and anyone
                        working to fund creative or community projects in
                        Montréal.
                    </p>
                </div>

                <div class="recap-highlights">
                    <div class="recap-section-label">What we'll cover</div>

                    <div class="highlight-item">
                        <span class="highlight-number">01</span>
                        <div class="highlight-content">
                            <h3>Lessons from the beta</h3>
                            <p>
                                Hear from organizations that have used Gia in
                                the first month — what worked, what surprised
                                them, and how the platform is evolving based on
                                community feedback.
                            </p>
                        </div>
                    </div>

                    <div class="highlight-item">
                        <span class="highlight-number">02</span>
                        <div class="highlight-content">
                            <h3>Grant strategy deep dive</h3>
                            <p>
                                A focused session on developing effective grant
                                strategies, including how to prioritize
                                opportunities, tailor applications, and build
                                relationships with funders over time.
                            </p>
                        </div>
                    </div>

                    <div class="highlight-item">
                        <span class="highlight-number">03</span>
                        <div class="highlight-content">
                            <h3>Open discussion & networking</h3>
                            <p>
                                Bring your questions, challenges, and ideas.
                                This is your time to connect with peers, get
                                specific advice, and contribute to shaping Gia's
                                future direction.
                            </p>
                        </div>
                    </div>

                    <div class="highlight-item">
                        <span class="highlight-number">04</span>
                        <div class="highlight-content">
                            <h3>Platform roadmap</h3>
                            <p>
                                Get a sneak peek at what's coming next for Gia —
                                new features, expanded grant databases, and
                                tools designed specifically for Montréal's arts
                                and nonprofit ecosystem.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Registration CTA -->
                <div class="registration-cta">
                    <h3>Registration opens soon</h3>
                    <p>Sign up to be notified when spots become available.</p>
                    <a href="#" class="btn-sidebar"
                        >🔔 Get notified when registration opens</a
                    >
                </div>
            </div>

            <!-- Sidebar -->
            <div class="event-sidebar">
                <div class="sidebar-card">
                    <h3>Event details</h3>
                    <div class="sidebar-details">
                        <div>
                            <div class="sidebar-detail-label">DATE</div>
                            <div class="sidebar-detail-value">
                                Coming soon — May 2026
                            </div>
                        </div>
                        <div>
                            <div class="sidebar-detail-label">TIME</div>
                            <div class="sidebar-detail-value">
                                8:30 – 10:00 am
                            </div>
                        </div>
                        <div>
                            <div class="sidebar-detail-label">LOCATION</div>
                            <div class="sidebar-detail-value">
                                Brique par Brique<br />Parc-Extension, Montréal
                            </div>
                        </div>
                        <div>
                            <div class="sidebar-detail-label">CAPACITY</div>
                            <div class="sidebar-detail-value">
                                ~35 participants
                            </div>
                        </div>
                    </div>
                </div>

                <div class="sidebar-card">
                    <h3>Who should attend</h3>
                    <ul class="sidebar-org-list">
                        <li>Artists seeking funding opportunities</li>
                        <li>Nonprofit leaders and staff</li>
                        <li>Grant writers and consultants</li>
                        <li>Social entrepreneurs</li>
                        <li>Anyone navigating Montréal's grant landscape</li>
                        <li>Previous Gia users and newcomers</li>
                    </ul>
                </div>

                <div class="sidebar-card">
                    <h3>Try Gia</h3>
                    <p
                        style="font-size: 14px; color: var(--text-mid); line-height: 1.6; margin-bottom: 16px;"
                    >
                        Can't wait for the event? Book a free 20-minute
                        discovery call with Jordane to explore grant
                        opportunities for your project.
                    </p>
                    <a href="/coming-soon" class="btn-sidebar"
                        >🌱 Book a free call</a
                    >
                </div>
            </div>
        </div>

        <!-- ─── NEXT EVENT CTA ─── -->
        <div class="next-event-cta">
            <h2>Join us for <em>Breakfast #02.</em></h2>
            <p>
                Be part of the growing community shaping Montréal's approach to
                grant funding. Limited spots available — sign up to be notified
                when registration opens.
            </p>
            <a href="#" class="btn-primary"
                >🔔 Notify me when registration opens</a
            >
        </div>
    </div>

    <!-- Event-specific scripts -->
    <script slot="scripts">
        // Notification signup functionality
        document.addEventListener("DOMContentLoaded", function () {
            const notifyButtons = document.querySelectorAll('a[href="#"]');
            notifyButtons.forEach((button) => {
                if (
                    button.textContent.includes("notify") ||
                    button.textContent.includes("Notify") ||
                    button.textContent.includes("🔔")
                ) {
                    button.addEventListener("click", function (e) {
                        e.preventDefault();
                        alert(
                            "Notification feature coming soon! We'll let you know when registration opens.",
                        );
                    });
                }
            });
        });
    </script>
</Layout>

<style>
    .page-content {
        padding-top: 80px;
    }

    /* Event-specific styles */
    .event-hero {
        padding: 0 24px;
        max-width: 1100px;
        margin: 0 auto;
    }

    .event-breadcrumb {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: var(--text-sm);
        color: var(--text-soft);
        margin-bottom: 24px;
        padding-top: 24px;
    }

    .event-breadcrumb a {
        color: var(--leaf);
        text-decoration: none;
    }

    .event-breadcrumb a:hover {
        text-decoration: underline;
    }

    .event-hero-grid {
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 32px;
        align-items: start;
        padding-bottom: 48px;
        border-bottom: 1px solid rgba(92, 122, 90, 0.15);
    }

    .event-tag-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .event-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(92, 122, 90, 0.1);
        border: 1px solid rgba(92, 122, 90, 0.2);
        border-radius: 100px;
        padding: 5px 12px;
        font-size: var(--text-xs);
        font-weight: 500;
        color: var(--leaf);
        letter-spacing: 0.3px;
    }

    .event-number-badge {
        font-size: var(--text-xs);
        color: var(--text-soft);
        letter-spacing: 0.5px;
    }

    .event-hero h1 {
        font-family: var(--font-serif);
        font-size: clamp(28px, 4vw, 48px);
        font-weight: 500;
        line-height: 1.1;
        letter-spacing: -1px;
        color: var(--text-dark);
        margin-bottom: 16px;
    }

    .event-hero h1 em {
        font-style: italic;
        color: var(--leaf);
    }

    .event-hero-desc {
        font-size: var(--text-md);
        color: var(--text-mid);
        line-height: 1.6;
        max-width: 560px;
    }

    /* Meta card */
    .event-meta-card {
        background: var(--white);
        border: 1.5px solid rgba(92, 122, 90, 0.15);
        border-radius: 16px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .meta-row {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .meta-label {
        font-size: var(--text-xs);
        font-weight: 500;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--text-soft);
    }

    .meta-value {
        font-size: var(--text-base);
        color: var(--text-dark);
        font-weight: 400;
    }

    .meta-divider {
        border: none;
        border-top: 1px solid rgba(92, 122, 90, 0.12);
    }

    .meta-tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .meta-tag {
        background: var(--cream-dark);
        border-radius: 100px;
        padding: 4px 11px;
        font-size: var(--text-xs);
        color: var(--text-mid);
    }

    /* Content Body */
    .event-body {
        max-width: 1100px;
        margin: 0 auto;
        padding: 48px 24px 0;
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 48px;
        align-items: start;
    }

    /* Recap left column */
    .event-recap {
        width: 100%;
    }

    .recap-section-label {
        font-size: var(--text-xs);
        font-weight: 500;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--leaf);
        margin-bottom: 16px;
    }

    .recap-summary h2 {
        font-family: var(--font-serif);
        font-size: clamp(20px, 2.5vw, 28px);
        font-weight: 500;
        letter-spacing: -0.5px;
        line-height: 1.2;
        color: var(--text-dark);
        margin-bottom: 16px;
    }

    .recap-summary h2 em {
        font-style: italic;
        color: var(--leaf);
    }

    .recap-summary p {
        font-size: var(--text-md);
        color: var(--text-mid);
        line-height: 1.7;
        margin-bottom: 16px;
    }

    /* Pull quote */
    .pull-quote {
        margin: 32px 0;
        padding: 24px 28px;
        background: rgba(92, 122, 90, 0.07);
        border-left: 3px solid var(--leaf);
        border-radius: 0 12px 12px 0;
    }

    .pull-quote blockquote {
        font-family: var(--font-serif);
        font-size: var(--text-lg);
        font-style: italic;
        color: var(--text-dark);
        line-height: 1.6;
        margin-bottom: 12px;
        letter-spacing: -0.2px;
    }

    .pull-quote cite {
        font-size: var(--text-sm);
        color: var(--text-soft);
        font-style: normal;
    }

    /* Highlights */
    .recap-highlights {
        margin-top: 40px;
    }

    .highlight-item {
        display: grid;
        grid-template-columns: 28px 1fr;
        gap: 16px;
        padding: 24px 0;
        border-bottom: 1px solid rgba(92, 122, 90, 0.1);
    }

    .highlight-item:first-of-type {
        border-top: 1px solid rgba(92, 122, 90, 0.1);
    }

    .highlight-number {
        font-family: var(--font-serif);
        font-size: var(--text-sm);
        font-style: italic;
        color: var(--leaf);
        padding-top: 3px;
    }

    .highlight-content h3 {
        font-family: var(--font-serif);
        font-size: var(--text-md);
        font-weight: 500;
        color: var(--text-dark);
        margin-bottom: 8px;
        letter-spacing: -0.2px;
    }

    .highlight-content p {
        font-size: var(--text-base);
        color: var(--text-mid);
        line-height: 1.6;
    }

    /* Sticky sidebar */
    .event-sidebar {
        position: sticky;
        top: 100px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .sidebar-card {
        background: var(--white);
        border: 1.5px solid rgba(92, 122, 90, 0.15);
        border-radius: 16px;
        padding: 24px;
    }

    .sidebar-card h3 {
        font-family: var(--font-serif);
        font-size: var(--text-md);
        font-weight: 500;
        color: var(--text-dark);
        margin-bottom: 12px;
    }

    .sidebar-attendee-count {
        font-size: 32px;
        font-family: var(--font-serif);
        font-weight: 500;
        color: var(--leaf);
        letter-spacing: -1px;
        line-height: 1;
        margin-bottom: 4px;
    }

    .sidebar-attendee-label {
        font-size: var(--text-sm);
        color: var(--text-soft);
        margin-bottom: 16px;
    }

    .sidebar-org-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .sidebar-org-list li {
        font-size: var(--text-sm);
        color: var(--text-mid);
        display: flex;
        align-items: flex-start;
        gap: 8px;
        line-height: 1.4;
    }

    .sidebar-org-list li::before {
        content: "·";
        color: var(--leaf);
        font-size: 16px;
        line-height: 1.1;
        flex-shrink: 0;
    }

    .sidebar-next {
        background: var(--leaf);
        border-radius: 16px;
        padding: 24px;
    }

    .sidebar-next h3 {
        font-family: var(--font-serif);
        font-size: var(--text-md);
        font-weight: 500;
        color: var(--white);
        margin-bottom: 10px;
    }

    .sidebar-next p {
        font-size: var(--text-sm);
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.55;
        margin-bottom: 16px;
    }

    .btn-sidebar {
        display: inline-block;
        background: var(--white);
        color: var(--leaf);
        padding: 10px 20px;
        border-radius: 100px;
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-sidebar:hover {
        background: var(--cream-dark);
    }

    /* Next Event CTA */
    .next-event-cta {
        background: var(--cream-dark);
        padding: 64px 24px;
        text-align: center;
        margin-top: 64px;
    }

    .next-event-cta h2 {
        font-family: var(--font-serif);
        font-size: clamp(22px, 3vw, 34px);
        font-weight: 500;
        letter-spacing: -0.8px;
        color: var(--text-dark);
        margin-bottom: 12px;
    }

    .next-event-cta h2 em {
        font-style: italic;
        color: var(--leaf);
    }

    .next-event-cta p {
        font-size: var(--text-md);
        color: var(--text-mid);
        margin-bottom: 24px;
        max-width: 420px;
        margin-left: auto;
        margin-right: auto;
    }

    .btn-primary {
        background: var(--leaf);
        color: var(--white);
        border: none;
        padding: 14px 28px;
        border-radius: 100px;
        font-family: var(--font-sans);
        font-size: var(--text-base);
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-primary:hover {
        background: var(--soil);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(61, 107, 58, 0.25);
    }

    /* Responsive */
    @media (max-width: 768px) {
        .event-hero-grid {
            grid-template-columns: 1fr;
            gap: 24px;
        }

        .event-body {
            grid-template-columns: 1fr;
            padding: 32px 24px 0;
        }

        .event-sidebar {
            position: static;
        }

        .next-event-cta {
            padding: 48px 24px;
        }
    }
</style>
