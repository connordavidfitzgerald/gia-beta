---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import { Font, type CssVariable } from "astro:assets";
const FONTS: CssVariable[] = ["--font-sans", "--font-serif"];
---

<Layout title="Breakfast #01 — The beta launch · Gia">
    <a href="/community" slot="nav-links" class="nav-link active"
        >Community Breakfasts</a
    >

    <div class="page-content">
        <!-- ─── EVENT HERO ─── -->
        <div class="event-hero">
            <div class="event-breadcrumb">
                <a href="/community">Community Breakfasts</a>
                <span>→</span>
                <span>Breakfast #01</span>
            </div>

            <div class="event-hero-grid">
                <div>
                    <div class="event-tag-row">
                        <span class="event-badge">✓ Recap</span>
                        <span class="event-number-badge"
                            >Breakfast #01 · April 17, 2026</span
                        >
                    </div>
                    <h1>The <em>beta launch</em><br />breakfast.</h1>
                    <p class="event-hero-desc">
                        Gia's first morning gathering — a room full of
                        nonprofits, artists, and grant writers at Brique par
                        Brique. The conversation that kicked everything off.
                    </p>
                </div>

                <div class="event-meta-card">
                    <div class="meta-row">
                        <span class="meta-label">Date</span>
                        <span class="meta-value">Thursday, April 17, 2026</span>
                    </div>
                    <hr class="meta-divider" />
                    <div class="meta-row">
                        <span class="meta-label">Time</span>
                        <span class="meta-value">8:30 – 10:00 am</span>
                    </div>
                    <hr class="meta-divider" />
                    <div class="meta-row">
                        <span class="meta-label">Location</span>
                        <span class="meta-value"
                            >Brique par Brique<br />Parc-Extension, Montréal</span
                        >
                    </div>
                    <hr class="meta-divider" />
                    <div class="meta-row">
                        <span class="meta-label">Attendees</span>
                        <span class="meta-value">~30 participants</span>
                    </div>
                    <hr class="meta-divider" />
                    <div class="meta-row">
                        <span class="meta-label">Topics</span>
                        <div class="meta-tags">
                            <span class="meta-tag">Beta launch</span>
                            <span class="meta-tag">OBNLs</span>
                            <span class="meta-tag">Artists</span>
                            <span class="meta-tag">Grant writing</span>
                            <span class="meta-tag">Parc-Extension</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ─── BODY: RECAP + SIDEBAR ─── -->
        <div class="event-body">
            <!-- Recap -->
            <div class="event-recap">
                <div class="recap-summary">
                    <div class="recap-section-label">Summary</div>
                    <h2>What <em>happened</em><br />that morning.</h2>
                    <p>
                        About thirty people pulled chairs around tables at
                        Brique par Brique on a Thursday morning in April. Some
                        knew each other; most didn't. What they had in common
                        was a project they were trying to fund and a familiar
                        frustration: the grant landscape in Québec is dense,
                        opaque, and almost designed to discourage people who
                        don't already know the system.
                    </p>
                    <p>
                        Jordane opened the conversation not with a pitch but
                        with a question: what's the most confusing part of
                        applying for grants right now? The answers came quickly.
                        Eligibility criteria that seem designed to exclude.
                        Applications written in language that doesn't match how
                        artists actually talk about their work. The feeling that
                        funders have already decided before the deadline.
                    </p>
                    <p>
                        Gia was introduced simply: a tool built to reduce that
                        friction — to surface the right programs, demystify the
                        criteria, and put an actual human expert in the room
                        when it counts. The beta was open. The first discovery
                        calls were being booked.
                    </p>
                </div>

                <div class="pull-quote">
                    <blockquote>
                        "I've been applying to the same three grants for four
                        years because I don't know what else exists. I didn't
                        realize how much I didn't know."
                    </blockquote>
                    <cite>— Attendee, independent musician, Montréal</cite>
                </div>

                <div class="recap-highlights">
                    <div class="recap-section-label">Key themes discussed</div>

                    <div class="highlight-item">
                        <span class="highlight-number">01</span>
                        <div class="highlight-content">
                            <h3>The visibility problem</h3>
                            <p>
                                Most participants were only aware of a handful
                                of programs — typically the ones they'd applied
                                to before or heard about through word of mouth.
                                Several had never applied to CALQ or the Conseil
                                des arts de Montréal despite being clearly
                                eligible. The core issue isn't competition; it's
                                that the landscape is genuinely hard to see.
                            </p>
                        </div>
                    </div>

                    <div class="highlight-item">
                        <span class="highlight-number">02</span>
                        <div class="highlight-content">
                            <h3>Language as a barrier</h3>
                            <p>
                                A recurring thread: grant applications ask you
                                to translate your work into funder language,
                                which often doesn't map to how artists and small
                                nonprofits actually describe what they do.
                                Writing that sounds authentic in a conversation
                                sounds wrong in an application form — and vice
                                versa. Several attendees mentioned having
                                applications declined without feedback.
                            </p>
                        </div>
                    </div>

                    <div class="highlight-item">
                        <span class="highlight-number">03</span>
                        <div class="highlight-content">
                            <h3>Success-fee model: the reaction</h3>
                            <p>
                                When Jordane explained the model — 100% free to
                                discover, 10% only if awarded — the room went
                                quiet for a second and then someone said "that's
                                the only model that makes sense for us." Several
                                organizations mentioned that the upfront cost of
                                grant writing consultants had previously put the
                                option out of reach entirely.
                            </p>
                        </div>
                    </div>

                    <div class="highlight-item">
                        <span class="highlight-number">04</span>
                        <div class="highlight-content">
                            <h3>The cooperative angle resonated</h3>
                            <p>
                                More than one person made a point of asking
                                about the cooperative structure. The fact that
                                Gia is built by a cooperative, not a SaaS
                                company, and serves the social economy sector
                                felt meaningful — not just as positioning but as
                                an actual reason to trust the tool and want it
                                to succeed.
                            </p>
                        </div>
                    </div>

                    <div class="highlight-item">
                        <span class="highlight-number">05</span>
                        <div class="highlight-content">
                            <h3>What people wanted to see next</h3>
                            <p>
                                The most common requests: better visibility into
                                deadlines, more information about acceptance
                                rates ("so we can decide where to put our
                                energy"), and notifications when relevant new
                                programs open. Several participants also asked
                                about artist-specific flows — the CALQ and
                                Canada Council landscape feels distinct enough
                                that a tailored experience would help.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="event-sidebar">
                <div class="sidebar-card">
                    <h3>Who was in the room</h3>
                    <div class="sidebar-attendee-count">~30</div>
                    <div class="sidebar-attendee-label">participants</div>
                    <ul class="sidebar-org-list">
                        <li>
                            Community organizations from Parc-Extension and
                            surrounding neighbourhoods
                        </li>
                        <li>Independent musicians and visual artists</li>
                        <li>Small cultural nonprofits (OBNLs)</li>
                        <li>Grant writers and arts administrators</li>
                        <li>Social enterprises and coops</li>
                        <li>Students from Concordia and UQAM</li>
                    </ul>
                </div>

                <div class="sidebar-next">
                    <h3>Breakfast #02 is coming</h3>
                    <p>
                        Date TBD — May 2026. Sign up to be notified when
                        registration opens.
                    </p>
                    <a href="/events/breakfast-02" class="btn-sidebar"
                        >Get notified →</a
                    >
                </div>

                <div class="sidebar-card">
                    <h3>Try Gia</h3>
                    <p
                        style="font-size: 14px; color: var(--text-mid); line-height: 1.6; margin-bottom: 16px;"
                    >
                        Book a free 20-minute discovery call with Jordane. All
                        discovery is free — you only pay if a grant is awarded.
                    </p>
                    <a href="/coming-soon" class="btn-sidebar"
                        >🌱 Book a free call</a
                    >
                </div>
            </div>
        </div>

        <!-- ─── NEXT EVENT CTA ─── -->
        <div class="next-event-cta">
            <h2>Come to <em>Breakfast #02.</em></h2>
            <p>
                The next gathering is coming in May 2026. Same place, same
                spirit — a bit further along.
            </p>
            <a href="/events/breakfast-02" class="btn-primary"
                >See event details →</a
            >
        </div>
    </div>

    <!-- Event-specific scripts -->
    <script slot="scripts">
        console.log("Breakfast #01 page loaded");
    </script>
</Layout>

<style>
    .page-content {
        padding-top: 80px;
    }

    /* Event-specific styles */
    .event-hero {
        padding: 0 24px;
        max-width: 1100px;
        margin: 0 auto;
    }

    .event-breadcrumb {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: var(--text-sm);
        color: var(--text-soft);
        margin-bottom: 24px;
        padding-top: 24px;
    }

    .event-breadcrumb a {
        color: var(--leaf);
        text-decoration: none;
    }

    .event-breadcrumb a:hover {
        text-decoration: underline;
    }

    .event-hero-grid {
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 32px;
        align-items: start;
        padding-bottom: 48px;
        border-bottom: 1px solid rgba(92, 122, 90, 0.15);
    }

    .event-tag-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .event-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(92, 122, 90, 0.1);
        border: 1px solid rgba(92, 122, 90, 0.2);
        border-radius: 100px;
        padding: 5px 12px;
        font-size: var(--text-xs);
        font-weight: 500;
        color: var(--leaf);
        letter-spacing: 0.3px;
    }

    .event-number-badge {
        font-size: var(--text-xs);
        color: var(--text-soft);
        letter-spacing: 0.5px;
    }

    .event-hero h1 {
        font-family: var(--font-serif);
        font-size: clamp(28px, 4vw, 48px);
        font-weight: 500;
        line-height: 1.1;
        letter-spacing: -1px;
        color: var(--text-dark);
        margin-bottom: 16px;
    }

    .event-hero h1 em {
        font-style: italic;
        color: var(--leaf);
    }

    .event-hero-desc {
        font-size: var(--text-md);
        color: var(--text-mid);
        line-height: 1.6;
        max-width: 560px;
    }

    /* Meta card */
    .event-meta-card {
        background: var(--white);
        border: 1.5px solid rgba(92, 122, 90, 0.15);
        border-radius: 16px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .meta-row {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .meta-label {
        font-size: var(--text-xs);
        font-weight: 500;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--text-soft);
    }

    .meta-value {
        font-size: var(--text-base);
        color: var(--text-dark);
        font-weight: 400;
    }

    .meta-divider {
        border: none;
        border-top: 1px solid rgba(92, 122, 90, 0.12);
    }

    .meta-tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .meta-tag {
        background: var(--cream-dark);
        border-radius: 100px;
        padding: 4px 11px;
        font-size: var(--text-xs);
        color: var(--text-mid);
    }

    /* Content Body */
    .event-body {
        max-width: 1100px;
        margin: 0 auto;
        padding: 48px 24px 0;
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 48px;
        align-items: start;
    }

    /* Recap left column */
    .event-recap {
        width: 100%;
    }

    .recap-section-label {
        font-size: var(--text-xs);
        font-weight: 500;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--leaf);
        margin-bottom: 16px;
    }

    .recap-summary h2 {
        font-family: var(--font-serif);
        font-size: clamp(20px, 2.5vw, 28px);
        font-weight: 500;
        letter-spacing: -0.5px;
        line-height: 1.2;
        color: var(--text-dark);
        margin-bottom: 16px;
    }

    .recap-summary h2 em {
        font-style: italic;
        color: var(--leaf);
    }

    .recap-summary p {
        font-size: var(--text-md);
        color: var(--text-mid);
        line-height: 1.7;
        margin-bottom: 16px;
    }

    /* Pull quote */
    .pull-quote {
        margin: 32px 0;
        padding: 24px 28px;
        background: rgba(92, 122, 90, 0.07);
        border-left: 3px solid var(--leaf);
        border-radius: 0 12px 12px 0;
    }

    .pull-quote blockquote {
        font-family: var(--font-serif);
        font-size: var(--text-lg);
        font-style: italic;
        color: var(--text-dark);
        line-height: 1.6;
        margin-bottom: 12px;
        letter-spacing: -0.2px;
    }

    .pull-quote cite {
        font-size: var(--text-sm);
        color: var(--text-soft);
        font-style: normal;
    }

    /* Highlights */
    .recap-highlights {
        margin-top: 40px;
    }

    .highlight-item {
        display: grid;
        grid-template-columns: 28px 1fr;
        gap: 16px;
        padding: 24px 0;
        border-bottom: 1px solid rgba(92, 122, 90, 0.1);
    }

    .highlight-item:first-of-type {
        border-top: 1px solid rgba(92, 122, 90, 0.1);
    }

    .highlight-number {
        font-family: var(--font-serif);
        font-size: var(--text-sm);
        font-style: italic;
        color: var(--leaf);
        padding-top: 3px;
    }

    .highlight-content h3 {
        font-family: var(--font-serif);
        font-size: var(--text-md);
        font-weight: 500;
        color: var(--text-dark);
        margin-bottom: 8px;
        letter-spacing: -0.2px;
    }

    .highlight-content p {
        font-size: var(--text-base);
        color: var(--text-mid);
        line-height: 1.6;
    }

    /* Sticky sidebar */
    .event-sidebar {
        position: sticky;
        top: 100px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .sidebar-card {
        background: var(--white);
        border: 1.5px solid rgba(92, 122, 90, 0.15);
        border-radius: 16px;
        padding: 24px;
    }

    .sidebar-card h3 {
        font-family: var(--font-serif);
        font-size: var(--text-md);
        font-weight: 500;
        color: var(--text-dark);
        margin-bottom: 12px;
    }

    .sidebar-attendee-count {
        font-size: 32px;
        font-family: var(--font-serif);
        font-weight: 500;
        color: var(--leaf);
        letter-spacing: -1px;
        line-height: 1;
        margin-bottom: 4px;
    }

    .sidebar-attendee-label {
        font-size: var(--text-sm);
        color: var(--text-soft);
        margin-bottom: 16px;
    }

    .sidebar-org-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .sidebar-org-list li {
        font-size: var(--text-sm);
        color: var(--text-mid);
        display: flex;
        align-items: flex-start;
        gap: 8px;
        line-height: 1.4;
    }

    .sidebar-org-list li::before {
        content: "·";
        color: var(--leaf);
        font-size: 16px;
        line-height: 1.1;
        flex-shrink: 0;
    }

    .sidebar-next {
        background: var(--leaf);
        border-radius: 16px;
        padding: 24px;
    }

    .sidebar-next h3 {
        font-family: var(--font-serif);
        font-size: var(--text-md);
        font-weight: 500;
        color: var(--white);
        margin-bottom: 10px;
    }

    .sidebar-next p {
        font-size: var(--text-sm);
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.55;
        margin-bottom: 16px;
    }

    .btn-sidebar {
        display: inline-block;
        background: var(--white);
        color: var(--leaf);
        padding: 10px 20px;
        border-radius: 100px;
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-sidebar:hover {
        background: var(--cream-dark);
    }

    /* Next Event CTA */
    .next-event-cta {
        background: var(--cream-dark);
        padding: 64px 24px;
        text-align: center;
        margin-top: 64px;
    }

    .next-event-cta h2 {
        font-family: var(--font-serif);
        font-size: clamp(22px, 3vw, 34px);
        font-weight: 500;
        letter-spacing: -0.8px;
        color: var(--text-dark);
        margin-bottom: 12px;
    }

    .next-event-cta h2 em {
        font-style: italic;
        color: var(--leaf);
    }

    .next-event-cta p {
        font-size: var(--text-md);
        color: var(--text-mid);
        margin-bottom: 24px;
        max-width: 420px;
        margin-left: auto;
        margin-right: auto;
    }

    .btn-primary {
        background: var(--leaf);
        color: var(--white);
        border: none;
        padding: 14px 28px;
        border-radius: 100px;
        font-family: var(--font-sans);
        font-size: var(--text-base);
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-primary:hover {
        background: var(--soil);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(61, 107, 58, 0.25);
    }

    /* Responsive */
    @media (max-width: 768px) {
        .event-hero-grid {
            grid-template-columns: 1fr;
            gap: 24px;
        }

        .event-body {
            grid-template-columns: 1fr;
            padding: 32px 24px 0;
        }

        .event-sidebar {
            position: static;
        }

        .next-event-cta {
            padding: 48px 24px;
        }
    }
</style>
